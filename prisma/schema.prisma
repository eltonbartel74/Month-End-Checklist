generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase/Vercel integration vars
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  BLOCKED
  DONE
}

model Task {
  id          String     @id @default(cuid())
  period      String?    // e.g. "2026-02" (optional for now)
  title       String
  owner       String?
  status      TaskStatus @default(NOT_STARTED)

  // extra fields (imported from spreadsheet)
  frequency   String?
  estHoursPm  String?
  dependency  String?

  // scheduling
  repeatEnabled Boolean   @default(false)
  dailyTime     String?   // "HH:MM" (optional)
  weeklyDays    Int[]     @default([]) // 1=Mon ... 7=Sun
  monthlyDay    Int?      // 1..31
  nextDueAt     DateTime?
  lastDoneAt    DateTime?

  dueAt       DateTime?
  etaAt       DateTime?
  blocker     String?
  notes       String?

  attachments Attachment[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Attachment {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  url         String
  path        String
  filename    String
  contentType String?
  sizeBytes   Int?

  createdAt   DateTime @default(now())

  @@index([taskId])
}
